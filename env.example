# ====================================
# FinTel — Environment Configuration
# ====================================
# Copy this file to .env and fill in your keys.
# All variables are OPTIONAL — the system degrades gracefully
# when keys are missing (see README for details).

# --- LLM Backend ---
# Default: local Ollama at localhost:11434
# Change these to point to any OpenAI-compatible endpoint
LLM_API_BASE=http://localhost:11434/v1
LLM_MODEL_NAME=llama3
LLM_API_KEY=not-needed

# Ollama-specific tuning (ESG module)
LLM_TIMEOUT=120
LLM_NUM_PREDICT=1024
LLM_MAX_RETRIES=3

# --- Market Data ---
# Finnhub: free tier at https://finnhub.io/register
FINNHUB_API_KEY=

# --- Web Search ---
# Tavily: free tier at https://tavily.com
TAVILY_API_KEY=

# --- Optional: Cloud LLM / HuggingFace ---
# Only needed if deploying to cloud without local Ollama
# HF_TOKEN=
# HF_API_BASE=
